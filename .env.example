# --- Brain (at least one required) ---
GROQ_API_KEY=gsk_xxx
GEMINI_API_KEY=xxx

# --- Deploying to Vercel? ---
# Chromium is bundled INTO the function (@sparticuz/chromium) — no browser
# service needed. But a serverless browser has no window, so you can't solve a
# LinkedIn CAPTCHA in it. Skip the login entirely by seeding an existing session:
#   DevTools → Application → Cookies → linkedin.com → copy `li_at`
# (You can also paste it into the app's connect screen instead of setting this.)
LINKEDIN_LI_AT=

# --- Optional: cloud browser with an interactive live view ---
# Only needed if you want to solve CAPTCHAs / watch the browser from the deployed
# site. Leave empty to use the bundled-Chromium path above.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
